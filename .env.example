# =====================
# BACKEND ENV VARS
# Set all of these in Render dashboard → Environment
# =====================

# PostgreSQL (get from Supabase → Project Settings → Database)
DB_URL=jdbc:postgresql://your-host.supabase.co:5432/postgres
DB_USER=postgres
DB_PASS=ROTATE_THIS_CHANGE_YOUR_SUPABASE_DB_PASSWORD

# JWT (generate fresh: openssl rand -base64 64)
JWT_SECRET=ROTATE_THIS_GENERATE_NEW_SECRET_MIN_32_CHARS

# Gmail App Password (generate new at myaccount.google.com/apppasswords)
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=ROTATE_THIS_GENERATE_NEW_GMAIL_APP_PASSWORD

# Supabase (get from Supabase → Project Settings → API)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=ROTATE_THIS_REGENERATE_SERVICE_ROLE_KEY

# Your Vercel frontend URL (for CORS)
APP_FRONTEND_URL=https://your-app.vercel.app

# NOTE: Do NOT set PORT — Render injects it automatically
